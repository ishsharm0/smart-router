{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.1.0",
  "name": "OpenRouter Full",
  "description": "Comprehensive model selection via OpenRouter. Best for users with OpenRouter API access and budget.",
  "provider": "openrouter",
  "pricing": {
    "type": "pay-per-token",
    "details": "Varies by model. See individual model costs."
  },
  "models": {
    "codex": {
      "id": "openai/gpt-5.3-codex",
      "name": "GPT-5.3 Codex",
      "provider": "openai",
      "context": 400000,
      "strengths": ["coding", "math", "reasoning", "agentic"],
      "benchmarks": {
        "swe-bench": 82.1,
        "aime-2025": 100,
        "intelligence-index": 91
      },
      "cost": { "input": 0.75, "output": 3.00, "unit": "per-1m-tokens" },
      "aliases": ["codex", "gpt-5", "gpt5", "openai-codex"],
      "enabled": true
    },
    "opus": {
      "id": "anthropic/claude-opus-4.6",
      "name": "Claude Opus 4.6",
      "provider": "anthropic",
      "context": 200000,
      "strengths": ["coding", "writing", "analysis", "adaptive-reasoning"],
      "benchmarks": {
        "swe-bench": 80.9,
        "gpqa-diamond": 89.2,
        "intelligence-index": 89
      },
      "cost": { "input": 15.00, "output": 75.00, "unit": "per-1m-tokens" },
      "aliases": ["opus", "claude-opus", "claude-4", "anthropic-opus"],
      "enabled": true
    },
    "sonnet": {
      "id": "anthropic/claude-sonnet-4.6",
      "name": "Claude Sonnet 4.6",
      "provider": "anthropic",
      "context": 200000,
      "strengths": ["balanced", "coding", "writing", "speed"],
      "benchmarks": {
        "swe-bench": 77.2,
        "gpqa-diamond": 84.1,
        "intelligence-index": 83
      },
      "cost": { "input": 3.00, "output": 15.00, "unit": "per-1m-tokens" },
      "aliases": ["sonnet", "claude-sonnet", "claude-3.7"],
      "enabled": true,
      "default": true
    },
    "gemini": {
      "id": "google/gemini-3.1-pro-preview",
      "name": "Gemini 3.1 Pro Preview",
      "provider": "google",
      "context": 1000000,
      "strengths": ["vision", "multimodal", "large-context", "video"],
      "benchmarks": {
        "swe-bench": 78.5,
        "gpqa-diamond": 87.9,
        "intelligence-index": 90,
        "mmmu-pro": 78.2
      },
      "cost": { "input": 0.50, "output": 2.00, "unit": "per-1m-tokens" },
      "aliases": ["gemini", "gemini-3", "google-gemini"],
      "enabled": true
    },
    "minimax": {
      "id": "minimax/minimax-m2.5",
      "name": "MiniMax M2.5",
      "provider": "minimax",
      "context": 205000,
      "strengths": ["coding", "fast-inference", "cost-effective"],
      "benchmarks": {
        "swe-bench": 80.2,
        "intelligence-index": 80
      },
      "cost": { "input": 0.30, "output": 1.20, "unit": "per-1m-tokens" },
      "aliases": ["minimax", "m2.5", "fast"],
      "enabled": true
    },
    "kimi": {
      "id": "moonshotai/kimi-k2.5",
      "name": "Kimi K2.5",
      "provider": "moonshot",
      "context": 256000,
      "strengths": ["vision", "agent-swarm", "browse-comp", "frontend"],
      "benchmarks": {
        "swe-bench": 76.8,
        "gpqa-diamond": 87.6,
        "intelligence-index": 85,
        "browse-comp": 78.4
      },
      "cost": { "input": 0.45, "output": 2.20, "unit": "per-1m-tokens" },
      "aliases": ["kimi", "k2.5", "moonshot"],
      "enabled": true
    },
    "deepseek": {
      "id": "deepseek/deepseek-v3.2-speciale",
      "name": "DeepSeek V3.2 Speciale",
      "provider": "deepseek",
      "context": 128000,
      "strengths": ["coding", "math", "cost-effective"],
      "benchmarks": {
        "swe-bench": 73.1,
        "math-500": 92.4,
        "intelligence-index": 78
      },
      "cost": { "input": 0.32, "output": 0.89, "unit": "per-1m-tokens" },
      "aliases": ["deepseek", "v3", "deepseek-v3"],
      "enabled": true
    }
  },
  "routing": {
    "fallback": "sonnet",
    "categories": {
      "heartbeat": {
        "model": "minimax",
        "priority": 100,
        "keywords": ["heartbeat_ok", "check_reminders", "internal heartbeat"]
      },
      "vision": {
        "model": "gemini",
        "priority": 95,
        "keywords": ["image", "pdf", "screenshot", "diagram", "chart", "graph", "visual", "picture", "photo", "video"]
      },
      "frontend": {
        "model": "kimi",
        "priority": 90,
        "keywords": ["css", "html", "component", "frontend", "react", "vue", "tailwind", "svelte", "styled", "layout", "responsive", "animation", "navbar", "modal", "tooltip", "dropdown", "theme", "dark mode"]
      },
      "coding-premium": {
        "model": "codex",
        "priority": 88,
        "keywords": ["critical bug", "production issue", "security", "optimize algorithm", "complex refactor"],
        "thresholds": { "minCodeFences": 3 }
      },
      "coding": {
        "model": "sonnet",
        "priority": 85,
        "keywords": ["code", "fix", "debug", "bug", "error", "function", "api", "implement", "refactor", "test", "not working", "broken", "failing"]
      },
      "complex": {
        "model": "opus",
        "priority": 82,
        "keywords": ["architecture", "system design", "explain", "explain why", "how does", "prove", "derive", "scientific", "mathematical", "theory", "hypothesis", "quantum", "physics", "chemistry", "biology"]
      },
      "writing": {
        "model": "sonnet",
        "priority": 70,
        "keywords": ["write", "draft", "edit", "compose", "rewrite", "polish", "email", "document", "report", "summary"]
      },
      "simple": {
        "model": "minimax",
        "priority": 50,
        "patterns": ["^\\s*(hi+|hello+|hey+|yo+|ok(?:ay)?|thanks?(?: you)?|ping|status|test(?:ing)?)[.!?\\s]*$"],
        "thresholds": { "maxWords": 8, "maxTokens": 150 }
      }
    }
  }
}
