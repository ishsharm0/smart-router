{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.0.1",
  "description": "Optimized routing: MiniMax for speed/coding, Qwen for reasoning fallback, Kimi for vision/frontend",
  "categories": {
    "frontend": {
      "model": "kimi",
      "priority": 90,
      "description": "UI/frontend work — Kimi excels at visual and component tasks",
      "triggers": {
        "keywords": [
          "css",
          "html",
          "component",
          "frontend",
          "react",
          "vue",
          "tailwind",
          "svelte",
          "styled",
          "layout",
          "responsive",
          "animation",
          "navbar",
          "modal",
          "tooltip",
          "dropdown",
          "theme",
          "dark mode"
        ]
      }
    },
    "vision": {
      "model": "kimi",
      "priority": 95,
      "description": "Image/PDF analysis — Kimi has best vision capabilities",
      "triggers": {
        "keywords": [
          "image",
          "pdf",
          "screenshot",
          "diagram",
          "chart",
          "graph",
          "visual",
          "picture",
          "photo"
        ]
      }
    },
    "complex": {
      "model": "qwen",
      "priority": 85,
      "description": "Science, math, deep reasoning — Qwen has best GPQA score (88.4%)",
      "triggers": {
        "keywords": [
          "architecture",
          "system design",
          "explain",
          "explain why",
          "how does",
          "prove",
          "derive",
          "scientific",
          "mathematical",
          "theory",
          "hypothesis",
          "quantum",
          "physics",
          "chemistry",
          "biology",
          "algorithm",
          "complexity",
          "optimize",
          "trade-off"
        ],
        "thresholds": {
          "minTokens": 200
        }
      }
    },
    "coding": {
      "model": "minimax",
      "priority": 80,
      "description": "Code, debug, fix — MiniMax has best SWE-Bench (80.2%)",
      "triggers": {
        "keywords": [
          "code",
          "fix",
          "debug",
          "bug",
          "error",
          "function",
          "api",
          "implement",
          "refactor",
          "test",
          "not working",
          "broken",
          "failing"
        ]
      }
    },
    "axiom": {
      "model": "minimax",
      "priority": 80,
      "description": "Axiom trading automation",
      "triggers": {
        "keywords": [
          "axiom",
          "start trading",
          "trading interface",
          "wallet tracker",
          "playwright",
          "cdp relay",
          "browser session"
        ]
      }
    },
    "heartbeat": {
      "model": "minimax",
      "priority": 100,
      "description": "Background maintenance — MiniMax for speed",
      "triggers": {
        "keywords": [
          "heartbeat_ok",
          "check_reminders_silent",
          "heartbeat maintenance",
          "internal heartbeat"
        ]
      }
    },
    "simple": {
      "model": "minimax",
      "priority": 50,
      "description": "Chat, pings, quick tasks — MiniMax is fastest",
      "triggers": {
        "patterns": [
          "^\\s*(hi+|hello+|hey+|yo+|ok(?:ay)?|thanks?(?: you)?|ping|status|test(?:ing)?)[.!?\\s]*$"
        ],
        "thresholds": {
          "maxWords": 8,
          "maxTokens": 150
        }
      }
    }
  },
  "fallback": {
    "model": "minimax",
    "description": "Default — MiniMax M2.5 for fast responses, best coding (80.2% SWE-Bench)"
  }
}
